{
  "name": "chat-service-sync",
  "version": "1.0.0",
  "description": "Allow to sync Chat service with Eclipse Foundation services.",
  "keywords": [
    "Eclipse Foundation",
    "Chat service",
    "matrix"
  ],
  "author": {
    "name": "Sébastien Heurtematte"
  },
  "license": "EPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://gitlab.eclipse.org/eclipsefdn/it/releng/chat-service/chat-service-sync.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "npm run clean && npm run lint && npx tsc",
    "changelog": "conventional-changelog -p angular -u",
    "changelog:update": "conventional-changelog -p angular -i CHANGELOG.md -s && git add CHANGELOG.md",
    "clean": "(rm -r ./dist || true)",
    "clean:all": "npm run clean && (rm -r ./node_modules || true)",
    "lint": "npx eslint --ext .ts --fix src/**/*.ts",
    "preversion": "npm run build",
    "postversion": "git push && git push --tags",
    "start": "export NODE_TLS_REJECT_UNAUTHORIZED=0 && node ./dist/index.js",
    "start-dev": "export NODE_ENV=dev && export NODE_TLS_REJECT_UNAUTHORIZED=0 && node ./dist/index.js",
    "upgrade": "npx npm-check -u",
    "version": "npm run build && npm run changelog:update"
  },
  "devDependencies": {
    "@types/axios": "^0.14.0",
    "@types/node": "^20.2.3",
    "@typescript-eslint/eslint-plugin": "^5.59.6",
    "@typescript-eslint/parser": "^5.59.6",
    "conventional-changelog-cli": "^2.2.2",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.41.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.2"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "axios": "^1.4.0",
    "config": "^3.3.9",
    "markdown-it": "^13.0.1",
    "matrix-js-sdk": "^25.1.1",
    "simple-oauth2": "^5.0.0",
    "sitka": "^1.0.6",
    "yaml": "^2.2.2"
  }
}
